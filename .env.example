# File Brain 环境变量配置
# 复制此文件为 .env 并修改配置

# ============================================
# 嵌入模型配置
# ============================================
# 可选值:
# - "tfidf" : 使用 TF-IDF (完全离线，基于关键词匹配，默认)
# - "sentence-transformers" : 使用 AI 嵌入模型 (首次需联网下载约80MB)
EMBEDDING_MODEL=tfidf

# ============================================
# AI 配置（默认：无 AI，完全离线）
# ============================================
# AI_PROVIDER 可选值:
# - "none" : 无 AI（完全离线，默认）
# - "ollama" : 使用 Ollama 本地模型（需安装 Ollama）
# - "lmstudio" : 使用 LM Studio（需启动 LM Studio 服务器）
# - "local" : 使用本地 transformers 小模型（首次需联网下载）
# - "openai" : 使用 OpenAI API（需密钥，数据发送到 OpenAI）
AI_PROVIDER=none

# --------------------------------------------
# Ollama 配置
# --------------------------------------------
# 安装: https://ollama.com/download
# 运行: ollama run llama2 (或 mistral、phi 等)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# --------------------------------------------
# LM Studio 配置
# --------------------------------------------
# 安装: https://lmstudio.ai/
# 在 LM Studio 中启用 "Local Inference Server"
LMSTUDIO_URL=http://localhost:1234/v1

# --------------------------------------------
# 本地 Transformers 配置
# --------------------------------------------
# 首次使用自动从 Hugging Face 下载
LOCAL_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0

# --------------------------------------------
# OpenAI 配置
# --------------------------------------------
# 注意：使用 OpenAI API 会将数据发送到 OpenAI 服务器
# 获取密钥: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_API_BASE=https://api.openai.com/v1

# ============================================
# Notion 集成 (可选)
# ============================================
# 从 https://www.notion.so/my-integrations 获取 API Key
NOTION_API_KEY=
NOTION_DATABASE_ID=

# ============================================
# Obsidian 集成 (可选)
# ============================================
# 你的 Obsidian 知识库路径
OBSIDIAN_VAULT_PATH=C:\Users\YourName\Documents\Obsidian Vault

# ============================================
# Google API (NotebookLM 集成，可选)
# ============================================
GOOGLE_API_KEY=
